{
  "$schema": "https://schema.cloudflare.net/workers",
  "name": "cloudflare-temp-email-worker",
  "main": "worker.js",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "temp_email_db"
    }
  ],
  "vars": {
    "ADMIN_PASSWORDS": "PrivateMailApi_6688"
  }
}
